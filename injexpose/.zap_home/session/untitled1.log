/*C5*/INSERT INTO ALERT VALUES(81,0,10055,'CSP: Failure to Define Directive with No Fallback',2,3,'The Content Security Policy fails to define one of the directives that has no fallback. Missing/excluding them is the same as allowing anything.','http://localhost:8081/vulnerabilities/csp/','Content-Security-Policy','The directive(s): frame-ancestors, form-action is/are among the directives that do not fallback to default-src.','Ensure that your web server, application server, load balancer, etc. is properly configured to set the Content-Security-Policy header.','https://www.w3.org/TR/CSP/\u000ahttps://caniuse.com/#search=content+security+policy\u000ahttps://content-security-policy.com/\u000ahttps://github.com/HtmlUnit/htmlunit-csp\u000ahttps://web.dev/articles/csp#resource-options',84,84,'','script-src ''self'' https://pastebin.com  example.com code.jquery.com https://ssl.google-analytics.com ;',693,15,3,'','http://localhost:8081/vulnerabilities/csp/','10055-13')
