/*C5*/INSERT INTO ALERT VALUES(121,0,10020,'Missing Anti-clickjacking Header',2,2,'The response does not protect against ''ClickJacking'' attacks. It should include either Content-Security-Policy with ''frame-ancestors'' directive or X-Frame-Options.','http://localhost:8081/instructions.php?doc=changelog','x-frame-options','','Modern Web browsers support the Content-Security-Policy and X-Frame-Options HTTP headers. Ensure one of them is set on all web pages returned by your site/app.\u000aIf you expect the page to be framed only by pages on your server (e.g. it''s part of a FRAMESET) then you''ll want to use SAMEORIGIN, otherwise if you never expect the page to be framed, you should use DENY. Alternatively consider implementing Content Security Policy''s "frame-ancestors" directive.','https://developer.mozilla.org/en-US/docs/Web/HTTP/Reference/Headers/X-Frame-Options',111,111,'','',1021,15,3,'','http://localhost:8081/instructions.php (doc)','10020-1')
