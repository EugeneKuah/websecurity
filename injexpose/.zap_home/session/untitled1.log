/*C5*/INSERT INTO ALERT VALUES(6,0,10031,'User Controllable HTML Element Attribute (Potential XSS)',0,1,'This check looks at user-supplied input in query string parameters and POST data to identify where certain HTML attribute values might be controlled. This provides hot-spot detection for XSS (cross-site scripting) that will require further review by a security analyst to determine exploitability.','http://localhost:8081/vulnerabilities/sqli/?id=1&Submit=Submit','Submit','User-controlled HTML attribute values were found. Try injecting special characters to see if XSS might be possible. The page at the following URL:\u000a\u000ahttp://localhost:8081/vulnerabilities/sqli/?id=1&Submit=Submit\u000a\u000aappears to include user input in:\u000aa(n) [input] tag [type] attribute\u000a\u000aThe user input found was:\u000aSubmit=Submit\u000a\u000aThe user-controlled value was:\u000asubmit','Validate all input and sanitize output it before writing to any HTML attributes.','https://cheatsheetseries.owasp.org/cheatsheets/Input_Validation_Cheat_Sheet.html',1,1,'','',20,20,3,'','http://localhost:8081/vulnerabilities/sqli/ (Submit,id)','10031')
COMMIT
