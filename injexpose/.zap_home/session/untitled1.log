/*C5*/INSERT INTO ALERT VALUES(84,0,10055,'CSP: style-src unsafe-inline',2,3,'Content Security Policy (CSP) is an added layer of security that helps to detect and mitigate certain types of attacks. Including (but not limited to) Cross Site Scripting (XSS), and data injection attacks. These attacks are used for everything from data theft to site defacement or distribution of malware. CSP provides a set of standard HTTP headers that allow website owners to declare approved sources of content that browsers should be allowed to load on that page \u2014 covered types are JavaScript, CSS, HTML frames, fonts, images and embeddable objects such as Java applets, ActiveX, audio and video files.','http://localhost:8081/vulnerabilities/csp/','Content-Security-Policy','style-src includes unsafe-inline.','Ensure that your web server, application server, load balancer, etc. is properly configured to set the Content-Security-Policy header.','https://www.w3.org/TR/CSP/\u000ahttps://caniuse.com/#search=content+security+policy\u000ahttps://content-security-policy.com/\u000ahttps://github.com/HtmlUnit/htmlunit-csp\u000ahttps://web.dev/articles/csp#resource-options',84,84,'','script-src ''self'' https://pastebin.com  example.com code.jquery.com https://ssl.google-analytics.com ;',693,15,3,'','http://localhost:8081/vulnerabilities/csp/','10055-6')
COMMIT
